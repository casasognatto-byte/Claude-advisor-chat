# Copie para .env e preencha. NUNCA versione o .env real.

# Sem isso, print() de diagnóstico ficam presos no buffer e não aparecem no
# log a tempo (ou nunca aparecem). Sempre deixe ligado, local e em produção.
PYTHONUNBUFFERED=1

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Opcional — system prompt do executor. Coloque aqui o contexto do Promob, ex.:
# SYSTEM_PROMPT=Você é um assistente especializado no Promob...
SYSTEM_PROMPT=

# --- Login / autenticação ---------------------------------------------------
# Login é por E-MAIL. O quadro fixo de usuários (ROSTER, em app/main.py) é
# aplicado a cada boot: o diretor (Davi) entra confirmado com a senha abaixo;
# os demais entram PENDENTES e recebem um e-mail de convite para confirmar o
# cadastro e definir a própria senha. Gestão adicional pelo painel /admin.

# Senha inicial do diretor (Davi Nogueira). Definida só se ele ainda não tiver
# senha; depois disso ele troca pela própria. Sem isso, nem o diretor loga.
SEED_DIRETOR_PASSWORD=

# --- E-mail (convite de cadastro + redefinição de senha) --------------------
# EMAIL_BACKEND: "console" (padrão) só ESCREVE o link no log, não envia nada —
# use em dev/teste. "smtp" envia de verdade. Nenhum e-mail real sai enquanto
# estiver em "console".
EMAIL_BACKEND=console
# Remetente exibido nos e-mails.
EMAIL_FROM=Casa Sognatto <nao-responder@casasognatto.com.br>
# Só quando EMAIL_BACKEND=smtp — credenciais da caixa @casasognatto.com.br
# (ou de um serviço transacional). Porta 465=SSL, 587=STARTTLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# SMTP_STARTTLS=true

# Chave para assinar o cookie de sessão. Gere uma aleatória e mantenha fixa
# (se mudar, todos precisam logar de novo). Ex.: um texto longo e aleatório.
SECRET_KEY=

# Em produção (HTTPS) deixe true. Só use false para testar local em http://.
COOKIE_SECURE=true

# URL pública deste serviço (ex: https://chat.casasognatto.com.br) — usada nos
# links de convite/redefinição de senha enviados por e-mail.
PUBLIC_BASE_URL=http://127.0.0.1:8000

# --- Banco de dados (login + histórico compartilhado da equipe) -------------
# String de conexão Postgres (Neon, Supabase, Render...). AGORA OBRIGATÓRIO —
# sem isso ninguém consegue logar (não há mais fallback "site aberto"). Ex.:
# DATABASE_URL=postgresql://user:senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Alerta ClickUp (pergunta sobre o stack de IA) ---------------------------
# Se qualquer pessoa perguntar qual IA/tecnologia está por trás da Neusa, o
# sistema detecta e manda uma mensagem de chat direta (DM) pro Davi no
# ClickUp. Sem CLICKUP_TOKEN, só loga no servidor (não quebra o chat).
# Testado de ponta a ponta em 2026-07-04 com token real.
CLICKUP_TOKEN=
# CLICKUP_WORKSPACE_ID=90133031055           # já é o padrão no código
# CLICKUP_ALERT_EMAIL=davinogueira@casasognatto.com.br  # já é o padrão no código

# --- Opcionais (têm padrões no código) --------------------------------------
# EXECUTOR_MODEL=claude-sonnet-4-6
# ADVISOR_MODEL=claude-opus-4-8
# MAX_TOKENS=4096
# ADVISOR_MAX_USES=3
# ADVISOR_MAX_TOKENS=2048
# SESSION_MAX_AGE=43200

# --- Geração de imagem (imagem elementar -> render fotorrealista) -----------
# IMPORTANTE (ver memória "Confidencialidade do stack de IA"): nunca expor o
# nome de fornecedor em nada visível às arquitetas — isso já é garantido no
# código, só documentando aqui pra quem for mexer no futuro.

# Motor padrão: stub | nanobanana. "stub" não chama fornecedor nenhum — só
# simula, útil pra testar sem gastar.
IMAGE_ENGINE=stub
# Chave do fornecedor (Nano Banana é via Gemini API) — só preencha quando for
# usar de verdade.
GOOGLE_API_KEY=
# IMAGE_MODEL (opcional, padrão no código: gemini-3-pro-image = Nano Banana
# Pro, melhor fidelidade a materiais/marcas específicas). Alternativa mais
# barata: gemini-3.1-flash-image (Nano Banana 2). NUNCA usar
# gemini-2.5-flash-image (Nano Banana original) — testado em produção
# (2026-07-07) e não seguiu bem nomes de material como "Suvinil crômio" e
# "quartzito Taj Mahal".
# Outro opcional (tem padrão no código): IMAGE_STORAGE_DIR

# --- Biblioteca de Apresentações (Fase 4: Neusa arquiteta auxiliar) ---------
# Armazenamento das imagens/vídeos de cada projeto de cliente. Sem as 4
# variáveis abaixo, cai automaticamente pra disco local (dev/teste, sem
# custo, mas não persiste entre deploys). Cloudflare R2 recomendado: sem
# custo de egress, $0,015/GB/mês, grátis até 10GB.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Opcional (só usado no fallback local, sem R2 configurado):
# PRESENTATIONS_STORAGE_DIR=

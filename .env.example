# Copie para .env e preencha. NUNCA versione o .env real.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Opcional — system prompt do executor. Coloque aqui o contexto do Promob, ex.:
# SYSTEM_PROMPT=Você é um assistente especializado no Promob...
SYSTEM_PROMPT=

# --- Login / autenticação ---------------------------------------------------
# Usuários agora vivem na tabela `users` (Postgres), gerida pelo painel /admin
# (só o diretor acessa). Nada de AUTH_USERS aqui — as duas variáveis abaixo só
# servem para a SEMEADURA INICIAL, quando a tabela `users` ainda está vazia.
# Depois da primeira execução, mude/adicione usuários só pelo painel.

# Senha inicial de "Davi Nogueira" (papel diretor). Obrigatória na 1ª execução;
# ignorada depois que a tabela já tiver usuários.
SEED_DIRETOR_PASSWORD=

# Senha padrão da equipe (Taynara Leandro, Júlia Mendes, Guilherme Orth) na
# semeadura inicial. Se ficar vazio, usa "C@s@1945".
SEED_MEMBER_PASSWORD=

# Chave para assinar o cookie de sessão. Gere uma aleatória e mantenha fixa
# (se mudar, todos precisam logar de novo). Ex.: um texto longo e aleatório.
SECRET_KEY=

# Em produção (HTTPS) deixe true. Só use false para testar local em http://.
COOKIE_SECURE=true

# --- Banco de dados (login + histórico compartilhado da equipe) -------------
# String de conexão Postgres (Neon, Supabase, Render...). AGORA OBRIGATÓRIO —
# sem isso ninguém consegue logar (não há mais fallback "site aberto"). Ex.:
# DATABASE_URL=postgresql://user:senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Opcionais (têm padrões no código) --------------------------------------
# EXECUTOR_MODEL=claude-sonnet-4-6
# ADVISOR_MODEL=claude-opus-4-8
# MAX_TOKENS=4096
# ADVISOR_MAX_USES=3
# ADVISOR_MAX_TOKENS=2048
# SESSION_MAX_AGE=43200

# --- Geração de vídeo (render -> vídeo animado) ------------------------------
# IMPORTANTE (ver memória "Confidencialidade do stack de IA"): nunca expor o
# nome de fornecedor em nada visível às arquitetas — isso já é garantido no
# código (app/video.py e app/static/index.html não têm nenhuma string de
# fornecedor), só documentando aqui pra quem for mexer no futuro.

# Motor padrão usado por todo mundo, exceto quando o diretor escolhe manualmente
# (toggle interno "Modo A/B", visível só pra ele). Valores: stub | luma | veo.
# "stub" não chama fornecedor nenhum — só simula, útil pra testar sem gastar.
VIDEO_ENGINE=stub

# Chaves dos fornecedores — só preencha quando for usar de verdade.
LUMA_API_KEY=
GOOGLE_API_KEY=

# URL pública deste serviço (ex: https://chat.casasognatto.com.br). Necessária
# só pro Luma, que precisa buscar a imagem hospedada por nós; em dev local use
# um túnel (ngrok) se for testar o Luma de verdade — sem isso, o Luma não
# consegue baixar a imagem.
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Opcionais (têm padrão no código):
# VIDEO_STAGE_TTL_SECONDS=1200
# VIDEO_POLL_INTERVAL_SECONDS=10
# VIDEO_STORAGE_DIR=

# --- Geração de imagem (imagem elementar -> render fotorrealista) -----------
# Motor padrão: stub | nanobanana. "stub" não chama fornecedor nenhum.
IMAGE_ENGINE=stub
# Reaproveita a mesma GOOGLE_API_KEY de cima (Nano Banana é via Gemini API).
# Opcionais (têm padrão no código): IMAGE_MODEL, IMAGE_STORAGE_DIR
